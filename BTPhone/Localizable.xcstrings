      }
    },
    "The other phone is muted" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Das andere Telefon ist stummgeschaltet" } }
      }
    },
    "No audio from the other phone — maybe a call or Siri" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kein Ton vom anderen Telefon — vielleicht ein Anruf oder Siri" } }
      }
    },
    "Open Settings" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Einstellungen öffnen" } }
      }
    },
    "Pair a different phone" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Ein anderes Telefon koppeln" } }
      }
    },
    "Hide pairing" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kopplung ausblenden" } }
      }
    },
    "Pairing a new phone doesn't remove old ones — manage pairings in iOS Settings." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Ein neues Telefon zu koppeln entfernt alte Kopplungen nicht — verwalte sie in den iOS-Einstellungen." } }
      }
    },
    "Multiple phones are paired — TwoUp connects to whichever responds first. Remove old pairings in iOS Settings." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mehrere Telefone sind gekoppelt — TwoUp verbindet sich mit dem, das zuerst antwortet. Entferne alte Kopplungen in den iOS-Einstellungen." } }
      }
    },
    "Can't reach the other phone. Make sure it's nearby with Wi-Fi on and TwoUp open." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Das andere Telefon ist nicht erreichbar. Es muss in der Nähe sein, mit eingeschaltetem WLAN und geöffnetem TwoUp." } }
      }
    },
    "Audio is stopped" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Audio ist gestoppt" } }
      }
    },
    "Restart audio" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Audio neu starten" } }
      }
    },
    "Microphone access is required. Enable it in Settings → Privacy → Microphone." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mikrofonzugriff wird benötigt. Aktiviere ihn unter Einstellungen → Datenschutz → Mikrofon." } }
      }
    },
    "Restart connection" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verbindung neu aufbauen" } }
      }
    },
    "Pair the two phones once" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die beiden Telefone einmalig koppeln" } }
      }
    },
    "On one phone tap Be discoverable, on the other tap Find other phone." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe auf einem Telefon auf „Sichtbar sein“, auf dem anderen auf „Anderes Telefon suchen“." } }
