    },
    "Free sessions run for 15 minutes — restart as often as you like. Or buy once and never think about it again: Family Sharing covers both phones with one purchase. No subscription." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gratis-Sitzungen laufen 15 Minuten — starte sie neu, so oft du willst. Oder kauf einmal und denk nie wieder daran: Dank Familienfreigabe reicht ein Kauf für beide Telefone. Kein Abo." } }
      }
    },
    "Unlock forever — %@" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Für immer freischalten — %@" } }
      }
    },
